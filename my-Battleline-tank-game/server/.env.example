# ── Tank Frontline environment variables ──────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

PORT=3000

# MongoDB connection string
# Local:  mongodb://localhost:27017/tankfrontline
# Docker: mongodb://mongo:27017/tankfrontline
MONGO_URI=mongodb://mongo:27017/tankfrontline

# JWT secret — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string
